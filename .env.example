# Porta exposta pela aplicação (Dockploy pode sobrescrever)
PORT=3000

# --- MongoDB (container "mongo") ---
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=troque-esta-senha
DB=disparo_whatsapp

# Usado fora do docker-compose (ex: rodando localmente sem Docker)
# DATABASE_URL=mongodb://root:troque-esta-senha@localhost:27017/?authSource=admin

# --- Segurança ---
# Segredo para assinar o JWT de sessão
JWT_SECRET=troque-por-um-valor-aleatorio-longo
# Segredo para criptografar credenciais sensíveis (ex: access token das contas WhatsApp Oficial)
APP_SECRET=troque-por-outro-valor-aleatorio-longo

# --- Seed do usuário administrador inicial ---
SEED_ADMIN_EMAIL=admin@disparo.local
SEED_ADMIN_PASSWORD=troque-apos-o-primeiro-login

# --- Meta Developer App (compartilhado — usado só pra validar webhooks de TODAS as contas) ---
# Token/phoneNumberId/wabaId de cada Conta WhatsApp Oficial são cadastrados na UI, não aqui.
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=troque-por-um-valor-aleatorio
META_GRAPH_API_VERSION=v21.0

# --- Baileys (canal não-oficial, Inbox) ---
BAILEYS_RECONNECT_MAX_BACKOFF_MS=60000
